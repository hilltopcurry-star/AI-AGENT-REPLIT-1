FROM node:20-slim

RUN apt-get update && apt-get install -y curl ca-certificates openssl tar gzip && rm -rf /var/lib/apt/lists/*

ARG FLYCTL_VERSION=0.4.29
RUN curl -fsSL "https://github.com/superfly/flyctl/releases/download/v${FLYCTL_VERSION}/flyctl_${FLYCTL_VERSION}_Linux_x86_64.tar.gz" \
      -o /tmp/flyctl.tar.gz \
    && tar -xzf /tmp/flyctl.tar.gz -C /usr/local/bin flyctl \
    && chmod +x /usr/local/bin/flyctl \
    && rm /tmp/flyctl.tar.gz \
    && flyctl version

WORKDIR /app

COPY package.json ./
RUN npm install --omit=dev && npx prisma generate || true

COPY . .

RUN npx prisma generate

ENV NODE_ENV=production
ENV PATH="/usr/local/bin:${PATH}"

CMD ["npx", "tsx", "worker/index.ts"]
