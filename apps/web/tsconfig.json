{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "/home/runner/workspace/.tmp-vitest/.next-test/types/**/*.ts",
    "/home/runner/workspace/.tmp-vitest/.next-test/dev/types/**/*.ts",
    "../../.tmp-vitest/.next-test/types/**/*.ts",
    "../../.tmp-vitest/.next-test/dev/types/**/*.ts",
    "../../.tmp-vitest/.next-test/dev/dev/types/**/*.ts",
    "../../.tmp-vitest/.next-plan-test/types/**/*.ts",
    "../../.tmp-vitest/.next-plan-test/dev/types/**/*.ts",
    "../../.tmp-vitest/.next-plan-only/types/**/*.ts",
    "../../.tmp-vitest/.next-plan-only/dev/types/**/*.ts",
    "../../.tmp-vitest/.next-stripe-test/types/**/*.ts",
    "../../.tmp-vitest/.next-stripe-test/dev/types/**/*.ts",
    "../../.tmp-vitest/.next-test2/types/**/*.ts",
    "../../.tmp-vitest/.next-test2/dev/types/**/*.ts",
    "../../.tmp-vitest/.next-test6/types/**/*.ts",
    "../../.tmp-vitest/.next-test6/dev/types/**/*.ts",
    "../../.tmp-vitest/.next-test7/types/**/*.ts",
    "../../.tmp-vitest/.next-test7/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
